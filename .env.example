# RustRelay Configuration
# Copy this file to .env:  copy .env.example .env
# Then change JWT_SECRET to any random string.

# Server
HOST=0.0.0.0
PORT=8080
NODE_ID=node-1

# PostgreSQL
# If you set a different password during PostgreSQL install, change it here.
DATABASE_URL=postgres://rustrelay:password@localhost:5432/rustrelay

# Redis / Memurai
# Default port is 6379 for both Redis and Memurai. No changes needed.
REDIS_URL=redis://localhost:6379

# Auth — CHANGE THIS to any random string
JWT_SECRET=change-me-to-a-long-random-string

# Tuning
HEARTBEAT_INTERVAL_SECS=30
HEARTBEAT_TIMEOUT_SECS=60
PRESENCE_OFFLINE_DEBOUNCE_SECS=5
READSTATE_FLUSH_INTERVAL_SECS=5
READSTATE_FLUSH_BATCH_SIZE=1000
CHANNEL_MEMBER_CACHE_TTL_SECS=300

# Observability
RUST_LOG=rustrelay=debug,tower_http=debug
METRICS_PORT=9090
